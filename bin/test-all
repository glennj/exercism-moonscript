#!/usr/bin/env bash
#
# shellcheck disable=SC2164

unset CDPATH

rm -fr test-exercises
cp -r exercises/practice test-exercises
cd test-exercises || exit 1

result=0

for exercise in *; do
    [[ -d $exercise ]] || continue

    echo
    echo "Testing $exercise..."
    pushd "$exercise" >/dev/null

    IFS=$'\t' read -r solution example < <(
        jq -r '.files | [.solution[0], .example[0]] | @tsv' .meta/config.json
    )

    mv "$example" "$solution"
    busted --verbose || (( ++result ))

    popd >/dev/null
done

exit $result
