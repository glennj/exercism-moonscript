#!/usr/bin/env moon

-- ref: https://github.com/exercism/lua/blob/main/bin/generate-spec

json = require 'dkjson'
-- require "moon.all"


file_exists = (path) ->
  f = io.open path, 'r'
  if f
    f\close()
    true
  else
    false


read_file = (path) ->
  f = assert(io.open(path, 'r'))
  contents = f\read('*a')
  f\close()
  contents


write_file = (path, contents) ->
  f = assert(io.open(path, 'w'))
  f\write(contents)
  f\close()


included_tests_from_toml = (path) ->
  included = {}
  local uuid, last_uuid
  line_no = 0

  for line in io.lines(path)
    line_no += 1
    for uuid in line\gmatch('%[([%x%-]+)%]')
      last_uuid = uuid
      included[uuid] = true

    if line\match('^include%s*=%s*false')
      -- p { uuid: (uuid or "nil"), last_uuid: (last_uuid or "nil"), :line, :line_no, :included }
      included[last_uuid] = nil

  included


exercise_name = arg[1]

exercise_directory = 'exercises/practice/' .. exercise_name

generator_module = "#{exercise_directory}/.meta/spec_generator.moon"

if not file_exists(generator_module)
  io.stderr\write "[ERROR] #{generator_module} does not exist\n"
  os.exit(5)


package.path = exercise_directory .. '/.meta/?.lua' .. ';' .. package.path

canonical_data_url = 'https://raw.githubusercontent.com/exercism/problem-specifications/main/exercises/' .. exercise_name .. '/canonical-data.json'
canonical_data_path = 'canonical-data/' .. exercise_name .. '.json'
spec_path = exercise_directory .. '/' .. exercise_name .. '_spec.moon'
tests_toml_path = exercise_directory .. '/.meta/tests.toml'

assert(os.execute('mkdir -p `dirname ' .. canonical_data_path .. '`'))
assert(os.execute('curl ' .. canonical_data_url .. ' -s -o ' .. canonical_data_path))

canonical_data_json = read_file(canonical_data_path)
canonical_data = json.decode(canonical_data_json)

-- moon.p { path: package.path }

assert(os.execute("moonc #{generator_module}"))
spec_generator = require('spec_generator')

included_tests = included_tests_from_toml(tests_toml_path)

process = (node) ->
  if node.cases
    output = {}

    if node.description
      table.insert(output, "describe '" .. node.description\lower! .. "', ->")
    else
      table.insert(output, "describe '" .. exercise_name .. "', ->")

      if spec_generator.test_helpers
        table.insert(output, spec_generator.test_helpers)

    cases = {}
    for _, case in ipairs(node.cases)
      if not case.uuid or included_tests[case.uuid]
        table.insert(cases, process(case))

    table.insert(output, table.concat(cases, '\n\n'))

    return table.concat(output, '\n')

  else
    template = [[
  it '%s', ->
%s]]

    return template\format(
      node.description,
      spec_generator.generate_test(node)
    )


spec = ([[
%s = require('%s')

%s
]])\format(spec_generator.module_name, exercise_name, process(canonical_data))

write_file(spec_path, spec)
-- os.execute('lua-format -i ' .. spec_path)
